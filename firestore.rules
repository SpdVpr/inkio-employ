rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Schedule tasks
    match /schedule_tasks/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /schedule_tasks_dev/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Employees
    match /employees/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /employees_dev/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Companies
    match /companies/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if true;
      allow write: if true;
      match /messages/{messageId} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}